# SAMUDRA AI — Environment Configuration
# Copy to .env and fill in actual values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here

# Port Configuration
PORT=5000

# Data Source Credentials
# CMEMS (Copernicus Marine Environment Monitoring Service)
CMEMS_USERNAME=your-cmems-username
CMEMS_PASSWORD=your-cmems-password
CMEMS_ENABLED=False

# NASA API (Earth Imagery)
NASA_API_KEY=your-nasa-api-key
NASA_ENABLED=False

# ECMWF (European Centre for Medium-Range Weather Forecasts)
ECMWF_API_KEY=your-ecmwf-api-key
ECMWF_ENABLED=False

# Application Configuration
REGION_LAT_MIN=14.0
REGION_LAT_MAX=21.0
REGION_LNG_MIN=67.0
REGION_LNG_MAX=74.5
REGION_NAME=Maharashtra EEZ, Arabian Sea

# Default Landing Port
DEFAULT_PORT=Ratnagiri

# Economic Configuration
GHOL_MARKET_PRICE=8500
SWIM_BLADDER_PRICE=70000
FUEL_COST_PER_KM=35
CREW_COST_PER_PERSON=600
