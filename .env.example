# ===========================
# DaryaSagar Environment Config
# ===========================
# Copy this to .env and fill in values

# Database
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://darya:your_secure_password_here@localhost:5432/daryasagar
DATABASE_SYNC_URL=postgresql://darya:your_secure_password_here@localhost:5432/daryasagar

# Cache
REDIS_URL=redis://localhost:6379

# Message Queue (Kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Supabase (Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.eyJ1Ijoi...

# Sentry Error Tracking
SENTRY_DSN=https://...@sentry.io/...

# Firebase (for FCM push notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY_ID=...
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@...
# Or pass the whole JSON as one variable:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# INCOIS (optional - if they provide API key)
INCOIS_API_KEY=

# JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Satellite / Ocean Data Sources (optional — falls back to mock if absent)
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=

# Environment
ENVIRONMENT=development
DEBUG=false
